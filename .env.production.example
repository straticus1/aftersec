# AfterSec Production Environment Variables
# Copy this file to .env and fill in the values

# Database Configuration
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgres://aftersec:${POSTGRES_PASSWORD}@pgbouncer:5432/aftersec

# Redis Configuration
REDIS_URL=redis://redis:6379

# JWT Authentication (CRITICAL: Generate a strong random secret)
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND

# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# LLM Budget Limits (USD)
LLM_DAILY_BUDGET=100.00
LLM_MONTHLY_BUDGET=2000.00

# Dark Web Threat Intelligence
DARKAPI_API_KEY=...
THREAT_INTEL_ENABLED=true

# OCI Configuration (for backups)
OCI_NAMESPACE=your-oci-namespace
OCI_BACKUP_BUCKET=aftersec-backups
OCI_REGION=us-ashburn-1

# Monitoring
GRAFANA_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Domain Configuration
DOMAIN=yourdomain.com

# Cloudflare Tunnel Token (optional, for Cloudflare Tunnel integration)
CLOUDFLARE_TUNNEL_TOKEN=...
